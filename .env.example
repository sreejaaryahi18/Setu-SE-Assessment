# Defaults to a local SQLite file if not set.
# To use Postgres instead, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/setu_reconciliation
DATABASE_URL=sqlite:///./setu.db

# Hours a transaction must sit in "processed but unsettled" state before
# it is surfaced as a reconciliation discrepancy (see README > Assumptions).
DISCREPANCY_MIN_AGE_HOURS=6
